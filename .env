# Konfiguracija PostgreSQL baze
POSTGRES_USER=postgres
POSTGRES_PASSWORD=devsecops_secret_pass
POSTGRES_DB=ticketing
# Interni URL unutar Docker mreže (ime servisa je 'postgres')
DATABASE_URL=postgresql://postgres:devsecops_secret_pass@postgres:5432/ticketing

# Konfiguracija Redisa
# Interni URL unutar Docker mreže (ime servisa je 'redis')
REDIS_URL=redis://redis:6379

# Portovi
PORT=8080